// Nordvolt / ElectroGadget data model.
//
// Structure follows backend/.claude/spec/navigation/navigation.spec.md — read
// that before changing anything here, especially §2.3 (why slugs are unique
// per-brand) and §2.3c (why Brand/Category carry a denormalized imageUrl
// alongside the Image table).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ImageStatus {
  pending
  processing
  uploaded
  failed
}

enum ImageOwnerType {
  product_gallery
  product_thumbnail
  seo_og
  brand
  category
}

enum TwitterCard {
  summary
  summary_large_image
  app
  player
}

enum AvailabilityStatus {
  in_stock
  out_of_stock
  preorder
}

// ─── Navigation hierarchy ────────────────────────────────────────────────────

model Brand {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  iconKey  String?
  /// Denormalized CDN url of the brand logo, written by the image worker when
  /// an upload completes. Exists so the sidebar query stays a two-level
  /// include instead of joining Image — see spec §2.3c.
  imageUrl String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  categories Category[]
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String
  imageUrl String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Adjacency-list tree. v1 renders only top-level rows (parentId IS NULL);
  // deeper nesting is storable now so adding it later needs no migration.
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  products ProductCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug is unique per brand, not globally: "phones" legitimately exists under
  // Samsung, Xiaomi, Google and OnePlus at once.
  @@unique([brandId, slug])
  @@index([brandId, isActive, sortOrder])
  @@index([parentId])
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Product {
  id             String  @id @default(cuid())
  name           String
  slug           String  @unique
  description    String?
  priceCents     Int
  compareAtCents Int?
  isActive       Boolean @default(true)

  // Nullable + unique reproduces Mongo's `sparse: true`: Postgres allows
  // unlimited NULLs in a unique column, so products without a SKU don't collide.
  sku     String? @unique
  barcode String? @unique

  rating             Float              @default(0)
  ratingCount        Int                @default(0)
  stock              Int                @default(0)
  availabilityStatus AvailabilityStatus @default(in_stock)

  warrantyInformation String?
  shippingInformation String?
  manufactureCountry  String?
  tags                String[]

  // Flat columns rather than a nested object: these are filtered individually
  // by shipping-cost rules, which a Json blob cannot index.
  weightGrams Int?
  widthMm     Int?
  heightMm    Int?
  depthMm     Int?

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  categories ProductCategory[]
  seo        ProductSeo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, isActive])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([priceCents])
}

// Explicit join table rather than an implicit m-n relation: the product flyout
// needs an order *within each category*, and implicit relations have nowhere to
// hang sortOrder.
model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

// Split from Product because it's written rarely and read only on the PDP,
// keeping the hot Product row narrow for list/sidebar queries.
model ProductSeo {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  metaTitle       String?     @db.VarChar(70)
  metaDescription String?     @db.VarChar(200)
  metaKeywords    String[]
  canonicalUrl    String?
  focusKeyword    String?
  ogTitle         String?     @db.VarChar(70)
  ogDescription   String?     @db.VarChar(200)
  twitterCard     TwitterCard @default(summary_large_image)
  /// JSON-LD. Json because it is genuinely schemaless and never queried by shape.
  structuredData  Json?
  noIndex         Boolean     @default(false)
  noFollow        Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Media ───────────────────────────────────────────────────────────────────

/// Deferred-upload image record. Rows are created immediately with
/// status=pending and a localPath; the BullMQ worker uploads to Cloudinary and
/// fills url/publicId. tries/lastError let failures surface in the dashboard
/// instead of vanishing.
///
/// One polymorphic table rather than an image column per model: the worker
/// scans `status: pending` across every owner type in a single query, which a
/// per-model layout cannot express. Trade-off — ownerId has no FK, so orphan
/// cleanup is handled in the service when an owner is deleted.
model Image {
  id        String      @id @default(cuid())
  url       String      @default("")
  publicId  String      @default("")
  status    ImageStatus @default(pending)
  localPath String      @default("")
  tries     Int         @default(0)
  lastError String      @default("")

  ownerType ImageOwnerType
  ownerId   String
  sortOrder Int            @default(0)
  alt       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerType, ownerId, sortOrder])
  @@index([status, tries])
}
