// Nordvolt / ElectroGadget data model.
//
// Structure follows backend/.claude/spec/navigation/navigation.spec.md — read
// that before changing anything here, especially §2.3 (why slugs are unique
// per-brand) and §2.3c (why Brand/Category carry a denormalized imageUrl
// alongside the Image table).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ImageStatus {
  pending
  processing
  uploaded
  failed
}

enum ImageOwnerType {
  product_gallery
  product_thumbnail
  seo_og
  brand
  category
  banner
  article_cover
}

/// draft/published control listing visibility; `archived` retires an article
/// from listings while keeping its URL resolvable, so inbound links and search
/// results don't 404 (article spec §2.8).
enum ArticleStatus {
  draft
  published
  archived
}

enum TwitterCard {
  summary
  summary_large_image
  app
  player
}

enum AvailabilityStatus {
  in_stock
  out_of_stock
  preorder
}

// ─── Navigation hierarchy ────────────────────────────────────────────────────

model Brand {
  id          String  @id @default(cuid())
  name        String
  /// Server-generated from name via slugify (brand.service.ts) — never accepted from the client.
  slug        String  @unique
  description String?
  iconKey     String?
  /// Denormalized CDN url of the brand logo, written by the image worker when
  /// an upload completes. Exists so the sidebar query stays a two-level
  /// include instead of joining Image — see spec §2.3c.
  imageUrl    String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  categories Category[]
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String?
  imageUrl    String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Adjacency-list tree. v1 renders only top-level rows (parentId IS NULL);
  // deeper nesting is storable now so adding it later needs no migration.
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  products ProductCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug is unique per brand, not globally: "phones" legitimately exists under
  // Samsung, Xiaomi, Google and OnePlus at once.
  @@unique([brandId, slug])
  @@index([brandId, isActive, sortOrder])
  @@index([parentId])
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  priceCents  Int
  isActive    Boolean @default(true)

  // Nullable + unique reproduces Mongo's `sparse: true`: Postgres allows
  // unlimited NULLs in a unique column, so products without a SKU don't collide.
  sku     String? @unique
  barcode String? @unique

  rating             Float              @default(0)
  ratingCount        Int                @default(0)
  stock              Int                @default(0)
  availabilityStatus AvailabilityStatus @default(in_stock)

  warrantyInformation String?
  shippingInformation String?
  manufactureCountry  String?
  tags                String[]

  // Flat columns rather than a nested object: these are filtered individually
  // by shipping-cost rules, which a Json blob cannot index.
  weightGrams Int?
  widthMm     Int?
  heightMm    Int?
  depthMm     Int?

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  categories ProductCategory[]
  seo        ProductSeo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, isActive])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([priceCents])
}

// Explicit join table rather than an implicit m-n relation: the product flyout
// needs an order *within each category*, and implicit relations have nowhere to
// hang sortOrder.
model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

// Split from Product because it's written rarely and read only on the PDP,
// keeping the hot Product row narrow for list/sidebar queries.
model ProductSeo {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  metaTitle       String?     @db.VarChar(70)
  metaDescription String?     @db.VarChar(200)
  metaKeywords    String[]
  canonicalUrl    String?
  focusKeyword    String?
  ogTitle         String?     @db.VarChar(70)
  ogDescription   String?     @db.VarChar(200)
  twitterCard     TwitterCard @default(summary_large_image)
  /// JSON-LD. Json because it is genuinely schemaless and never queried by shape.
  structuredData  Json?
  noIndex         Boolean     @default(false)
  noFollow        Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketing ───────────────────────────────────────────────────────────────

/// Homepage promo carousel slide. Deliberately minimal (spec §2.2): no slug
/// (never addressable by URL), no sortOrder (ordering is createdAt DESC, §2.4),
/// and no imageUrl column — banners join Image by ownerId the way Product does
/// rather than denormalizing like Brand/Category (§2.1).
model Banner {
  id          String  @id @default(cuid())
  title       String
  /// Required, not optional: the carousel always renders a subtitle line, and a
  /// null would leave a visible empty gap in the overlay.
  description String
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Serves the storefront's exact query: WHERE isActive ORDER BY createdAt DESC.
  @@index([isActive, createdAt(sort: Desc)])
}

// ─── Editorial ───────────────────────────────────────────────────────────────

/// Editorial article (blog post / buying guide). Unlike Banner, articles are
/// addressable by URL, so they carry a unique slug the way Product does.
///
/// No `excerpt` column (spec §2.11): the card design shows no summary line, and
/// the SEO metaDescription falls back to a truncation of `content` derived at
/// read time rather than a stored copy that would drift on every edit.
model Article {
  id    String @id @default(cuid())
  title String
  /// Derived server-side from `title` (slugify + -2/-3 collision suffix), never
  /// client-supplied — see spec §2.10. Write-once: not regenerated when the
  /// title changes, because a published URL is in search indexes already.
  slug  String @unique
  /// Markdown body, not Json: it's an authored document rendered as-is, so an
  /// editor-specific JSON schema would lock content to that editor forever
  /// (spec §2.7). Requires sanitization at render time.
  content String

  /// Nullable: there is no User model in this backend yet (spec §1.3), so a
  /// byline is a plain string until auth lands. Additive path to a real FK.
  authorName String?
  tags       String[]

  status      ArticleStatus @default(draft)
  /// Set when status first flips to published; this is the date rendered on
  /// every card — not createdAt, so an article drafted in March and published
  /// in June displays June. Never cleared on unpublish (spec §2.4).
  publishedAt DateTime?

  /// Denormalized counter incremented fire-and-forget on detail reads. Not an
  /// event table: the design shows only a total, so per-view rows would be
  /// written and never queried. Deliberately does not bust the cache on
  /// increment, or every read would invalidate itself (spec §2.5).
  viewCount Int @default(0)

  seo ArticleSeo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Serves the storefront's exact query:
  // WHERE status = 'published' ORDER BY publishedAt DESC.
  @@index([status, publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Mirrors ProductSeo exactly — same columns, same VarChar caps, same cascade.
/// Articles are the most SEO-sensitive content in the storefront, so they get
/// the full set rather than a subset.
model ArticleSeo {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  metaTitle       String?     @db.VarChar(70)
  metaDescription String?     @db.VarChar(200)
  metaKeywords    String[]
  canonicalUrl    String?
  focusKeyword    String?
  ogTitle         String?     @db.VarChar(70)
  ogDescription   String?     @db.VarChar(200)
  twitterCard     TwitterCard @default(summary_large_image)
  /// JSON-LD. Json because it is genuinely schemaless and never queried by shape.
  structuredData  Json?
  noIndex         Boolean     @default(false)
  noFollow        Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Media ───────────────────────────────────────────────────────────────────

/// Deferred-upload image record. Rows are created immediately with
/// status=pending and a localPath; the BullMQ worker uploads to Cloudinary and
/// fills url/publicId. tries/lastError let failures surface in the dashboard
/// instead of vanishing.
///
/// One polymorphic table rather than an image column per model: the worker
/// scans `status: pending` across every owner type in a single query, which a
/// per-model layout cannot express. Trade-off — ownerId has no FK, so orphan
/// cleanup is handled in the service when an owner is deleted.
model Image {
  id        String      @id @default(cuid())
  url       String      @default("")
  publicId  String      @default("")
  status    ImageStatus @default(pending)
  localPath String      @default("")
  tries     Int         @default(0)
  lastError String      @default("")

  ownerType ImageOwnerType
  ownerId   String
  sortOrder Int            @default(0)
  alt       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerType, ownerId, sortOrder])
  @@index([status, tries])
}
